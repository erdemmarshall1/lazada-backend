PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/lazada?retryWrites=true&w=majority
JWT_SECRET=your_secure_jwt_secret_key
JWT_EXPIRES_IN=7d
UPLOAD_PATH=./uploads

# Cloudinary — set these via environment variables or .env
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
